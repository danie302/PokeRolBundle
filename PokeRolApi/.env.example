# Environment Configuration
NODE_ENV=development

# Vercel Deployment (automatically set in production)
# NODE_ENV=production
# VERCEL=1

# Database
# For local development:
MONGODB_URI=mongodb://localhost:27017/pokerol
# For production (MongoDB Atlas or Vercel Postgres):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/pokerol?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_here

# Email Configuration (SMTP)
# For Mailchimp Mandrill:
EMAIL_HOST=smtp.mandrillapp.com
EMAIL_PORT=587
EMAIL_SECURE=true
EMAIL_USER=your_mailchimp_username
EMAIL_PASSWORD=your_mandrill_api_key
EMAIL_FROM=noreply@pokerol.com

# Frontend URL (for password reset links)
# For local development:
FRONTEND_URL=http://localhost:5173
# For production (update with your actual frontend URL):
# FRONTEND_URL=https://your-frontend-domain.com

# Alternative Email Providers:
#
# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_SECURE=true
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your_sendgrid_api_key
#
# Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_SECURE=true
# EMAIL_USER=your_mailgun_username
# EMAIL_PASSWORD=your_mailgun_password
#
# For development/testing, you can use Ethereal:
# Generate test credentials at https://ethereal.email/
